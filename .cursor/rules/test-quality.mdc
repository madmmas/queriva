## SECTION C — Python Test Rules

### C1 — Use pytest with fixtures, not setUp/tearDown
```python
# BAD (unittest style)
class TestEmbedSidecar(unittest.TestCase):
    def setUp(self):
        self.client = TestClient(app)

# GOOD
@pytest.fixture
def client():
    return TestClient(app)

def test_embed_returns_768_dims_for_labse(client):
    response = client.post("/api/embed", json={"text": "hello", "model": "LaBSE"})
    assert response.status_code == 200
    assert response.json()["dimensions"] == 768
```

### C2 — Mock HTTP calls with pytest-httpx or respx
Do not make real HTTP calls in unit tests.

```python
# embed-sidecar calling an external model download (mocked)
def test_model_load_failure_returns_503(client, respx_mock):
    respx_mock.post("https://huggingface.co/...").mock(side_effect=httpx.ConnectError)
    response = client.post("/api/embed", json={"text": "test", "model": "unknown-model"})
    assert response.status_code == 503
    assert "could not be loaded" in response.json()["detail"]
```

### C3 — Use parametrize for multiple input cases
```python
@pytest.mark.parametrize("model,expected_dims", [
    ("LaBSE", 768),
    ("all-MiniLM-L6-v2", 384),
    ("paraphrase-multilingual-mpnet-base-v2", 768),
])
def test_embed_returns_correct_dimensions(client, model, expected_dims):
    response = client.post("/api/embed", json={"text": "test", "model": model})
    assert response.json()["dimensions"] == expected_dims
```

### C4 — Use tmp_path fixture for file-based tests
Never write to absolute paths or use hardcoded filenames in tests.

```python
def test_json_loader_reads_all_documents(tmp_path):
    fixture = tmp_path / "articles.json"
    fixture.write_text('[{"id": "1", "title": "Test", "body": "..."}]')

    docs = json_loader.load(str(fixture))

    assert len(docs) == 1
    assert docs[0]["title"] == "Test"
```

### C5 — Assert response shape, not just status code
```python
# BAD
def test_embed_endpoint(client):
    response = client.post("/api/embed", json={"text": "test"})
    assert response.status_code == 200

# GOOD
def test_embed_endpoint_returns_vector_and_dimensions(client):
    response = client.post("/api/embed", json={"text": "flood in Dhaka", "model": "LaBSE"})

    assert response.status_code == 200
    body = response.json()
    assert "vector" in body
    assert "dimensions" in body
    assert body["dimensions"] == 768
    assert len(body["vector"]) == 768
    assert all(isinstance(v, float) for v in body["vector"])
```

### C6 — CLI tests use subprocess, not direct function calls
Test the CLI as a black box via `subprocess.run` to catch argument parsing
errors and exit codes that function-level tests miss.

```python
def test_cli_exits_nonzero_on_missing_required_args():
    result = subprocess.run(
        ["python", "queriva_ingest.py"],
        capture_output=True, text=True
    )
    assert result.returncode != 0
    assert "--collection" in result.stderr or "required" in result.stderr
```

### C7 — Coverage enforced via pytest-cov in CI
```ini
# pytest.ini or pyproject.toml
[tool.pytest.ini_options]
addopts = "--cov=. --cov-report=term-missing --cov-fail-under=80"
```

