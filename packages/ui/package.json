{
  "name": "@queriva/ui",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --config vitest.config.ts --coverage",
    "test-unit": "vitest run --config vitest.config.ts --coverage",
    "test-int": "echo 'No integration tests yet — E2E in issue #28'",
    "preview": "vite preview --port 5173 --strictPort",
    "build:host": "npm --prefix examples/host run build",
    "clean": "rm -rf dist node_modules/.vite coverage"
  },
  "dependencies": {
    "@tabler/icons-react": "3.44.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "1.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "jest-axe": "9.0.0",
    "jsdom": "25.0.1",
    "msw": "2.7.0",
    "typescript": "5.7.3",
    "vite": "6.0.7",
    "vitest": "2.1.8"
  }
}
