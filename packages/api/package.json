{
  "name": "@queriva/api",
  "private": true,
  "scripts": {
    "build": "mvn package -q -DskipTests",
    "test": "mvn test -q",
    "test-unit": "mvn test -q -Dgroups=unit -DexcludedGroups=integration,slow 2>/dev/null || mvn test -q",
    "test-int": "mvn test -q -Dgroups=integration 2>/dev/null || echo 'No integration tests yet'",
    "clean": "mvn clean -q"
  }
}
