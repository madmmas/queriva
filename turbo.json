{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "target/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test-unit": {
      "dependsOn": ["build"]
    },
    "test-int": {
      "dependsOn": ["build"]
    },
    "clean": {
      "cache": false
    }
  }
}
