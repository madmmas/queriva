# Ingestion
INGEST_DEFAULT_CHUNK_SIZE=512
INGEST_DEFAULT_OVERLAP=64
INGEST_DEFAULT_UPSERT_MODE=skip_existing
INGEST_BATCH_SIZE=32

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Embed Sidecar
EMBED_SIDECAR_URL=http://localhost:8001
EMBED_DEFAULT_MODEL=LaBSE
DEFAULT_MODEL=LaBSE
PORT=8001

# API
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Search
SEARCH_DEFAULT_TOP_K=10
# LaBSE cosine on news corpora often lands ~0.3–0.55; 0.40 shows seeded demo hits.
SEARCH_MIN_SCORE=0.40
SEARCH_MAX_SCORE_AUTO_ACCEPT=0.80

# UI
VITE_API_URL=http://localhost:8080
VITE_DEFAULT_COLLECTION=news_radar
# Vite only reads VITE_* — keep in sync with SEARCH_MIN_SCORE
VITE_SEARCH_MIN_SCORE=0.40
